generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InterventionCategory {
  VITAMIN_MINERAL
  FATTY_ACID
  AMINO_ACID
  BOTANICAL_HERBAL
  FIBER_PREBIOTIC_PROBIOTIC
  ERGOGENIC_PERFORMANCE_SUPPLEMENT
  NOOTROPIC
  HORMONAL_ENDOCRINE_INTERVENTION
  PEPTIDE_BIOLOGIC
  DRUG_GEROPROTECTOR_WATCHLIST
  FOOD_BEVERAGE
}

enum OutcomeArea {
  MORTALITY_LIFESPAN
  CARDIOVASCULAR_EVENTS
  LDL_APOB_LIPIDS
  BLOOD_PRESSURE
  GLUCOSE_INSULIN_HBA1C
  INFLAMMATION
  COGNITION
  SLEEP
  MOOD_STRESS
  MUSCLE_STRENGTH
  VO2_MAX_ENDURANCE
  JOINT_TENDON_SKIN
  EYE_HEALTH
  IMMUNE_RESPIRATORY
  FERTILITY_HORMONES
  BIOLOGICAL_AGING_CLOCKS
  SAFETY_ADVERSE_EFFECTS
}

enum EvidenceLabel {
  CORE_EVIDENCE_BASED
  CONDITIONAL_BIOMARKER_GATED
  USEFUL_FOR_SPECIFIC_USE_CASE
  REASONABLE_N_OF_1_EXPERIMENT
  SPECULATIVE_WATCHLIST
  SAFETY_CONCERN
  AVOID_NOT_RECOMMENDED
  REQUIRES_CLINICIAN_OVERSIGHT
  REGULATORY_CONCERN
  INSUFFICIENT_EVIDENCE
}

enum EvidenceMomentum {
  INCREASING
  STABLE
  CONFLICTING
  WEAKENING
  SAFETY_CONCERN_EMERGING
}

enum ReviewStatus {
  UNREVIEWED_AI_DRAFT
  HUMAN_REVIEWED
}

enum ConfidenceLevel {
  HIGH
  MODERATE
  LOW
  VERY_LOW
}

enum StudyType {
  META_ANALYSIS
  SYSTEMATIC_REVIEW
  RANDOMIZED_CONTROLLED_TRIAL
  OBSERVATIONAL_COHORT
  CASE_REPORT
  ANIMAL_STUDY
  IN_VITRO_MECHANISTIC
  CLINICAL_TRIAL_RECORD
  REGULATORY_SAFETY_WARNING
}

enum TrialStatus {
  RECRUITING
  ACTIVE
  COMPLETED
  TERMINATED
  RESULTS_PENDING
}

enum SafetyAlertType {
  LIVER_INJURY
  KIDNEY_RISK
  CONTAMINATION
  ADULTERATION
  MISLABELING
  PROHIBITED_IN_SPORT
  PRESCRIPTION_ONLY
  UNAPPROVED_THERAPEUTIC_GOOD
  COMPOUNDING_RESTRICTION
  DRUG_INTERACTION
}

enum SafetySeverity {
  LOW
  MODERATE
  HIGH
  CLINICIAN_REVIEW_RECOMMENDED
  AVOID
}

enum SourceKind {
  PUBMED
  PUBMED_CENTRAL
  CLINICALTRIALS_GOV
  NIH_ODS
  TGA
  FDA
  WADA
  LIVERTOX
  NCCIH
  MEDLINEPLUS
  PRODUCT_LABEL
  ADMIN_ENTRY
  OTHER
}

enum IngestionStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  SKIPPED
}

enum SourceCandidateDecision {
  PENDING_REVIEW
  ACCEPTED
  REJECTED
}

enum AustraliaRegulatoryKind {
  AUST_L
  AUST_LA
  AUST_R
  NOT_IN_ARTG
  UNAPPROVED
  EXEMPT
  EXCLUDED
  UNKNOWN
}

enum OperatorRole {
  OWNER
  ADMIN
  REVIEWER
  AUDITOR
}

enum OperatorStatus {
  ACTIVE
  DISABLED
}

model Intervention {
  id                        String               @id @default(cuid())
  slug                      String               @unique
  name                      String
  synonyms                  String[]
  category                  InterventionCategory
  commonForms               String[]
  commonStudyDoses          String[]
  consumerProductDoseRanges String[]
  regulatorySummary         String
  australiaRegulatoryStatus String
  safetySummary             String
  interactionSummary        String
  evidenceSummary           String
  lastReviewedAt            DateTime?
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  claims                      Claim[]
  trials                      Trial[]
  products                    Product[]
  safetyAlerts                SafetyAlert[]
  sourceCandidates            SourceCandidate[]
  ingestionJobs               IngestionJob[]
  australiaRegulatoryStatuses AustraliaRegulatoryStatus[]

  @@index([category])
  @@index([name])
}

model Claim {
  id                      String           @id @default(cuid())
  interventionId          String
  outcome                 OutcomeArea
  claimText               String
  populationStudied       String
  doseFormStudied         String
  durationStudied         String
  comparator              String
  evidenceGrade           String
  effectSize              String
  clinicalRelevance       String
  confidenceLevel         ConfidenceLevel
  safetyNotes             String
  applicabilityNotes      String
  evidenceDirectnessScore Int
  evidenceRigorScore      Int
  effectSizeScore         Int
  safetyScore             Int
  regulatoryRiskScore     Int
  productQualityScore     Int
  hypePenalty             Int
  measurabilityScore      Int
  finalLabel              EvidenceLabel
  momentum                EvidenceMomentum
  reviewStatus            ReviewStatus     @default(UNREVIEWED_AI_DRAFT)
  summary                 String?
  uncertainty             String?
  whatWouldChangeScore    String
  lastReviewedAt          DateTime?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  intervention     Intervention      @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  references       ClaimReference[]
  sourceCandidates SourceCandidate[]
  ingestionJobs    IngestionJob[]

  @@unique([interventionId, outcome, claimText])
  @@index([outcome])
  @@index([finalLabel])
  @@index([reviewStatus])
}

model Reference {
  id         String     @id @default(cuid())
  title      String
  source     SourceKind
  identifier String?
  year       Int?
  url        String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  claimLinks                  ClaimReference[]
  studies                     Study[]
  sourceDocuments             SourceDocument[]
  acceptedSourceCandidates    SourceCandidate[]
  australiaRegulatoryStatuses AustraliaRegulatoryStatus[]

  @@unique([url])
  @@index([source])
}

model ClaimReference {
  claimId     String
  referenceId String
  relevance   Int     @default(5)
  note        String?

  claim     Claim     @relation(fields: [claimId], references: [id], onDelete: Cascade)
  reference Reference @relation(fields: [referenceId], references: [id], onDelete: Cascade)

  @@id([claimId, referenceId])
}

model Study {
  id                String    @id @default(cuid())
  referenceId       String?
  title             String
  year              Int?
  source            String
  sourceType        StudyType
  pmid              String?
  pmcid             String?
  doi               String?
  nctId             String?
  url               String?
  abstract          String?
  sampleSize        String
  population        String
  interventionName  String
  dose              String?
  duration          String?
  outcomes          String[]
  mainResults       String?
  adverseEvents     String
  fundingConflicts  String
  riskOfBias        String
  relevanceScore    Int       @default(5)
  extractedAbstract String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  reference Reference? @relation(fields: [referenceId], references: [id], onDelete: SetNull)

  @@index([sourceType])
  @@index([pmid])
  @@index([nctId])
}

model Trial {
  id             String           @id @default(cuid())
  interventionId String?
  nctId          String?          @unique
  title          String
  status         TrialStatus
  phase          String
  enrollment     String
  conditions     String[]
  interventions  String[]
  outcomes       String[]
  startDate      DateTime?
  completionDate DateTime?
  lastUpdateDate DateTime?
  resultsPosted  Boolean          @default(false)
  evidenceImpact EvidenceMomentum
  url            String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  intervention Intervention? @relation(fields: [interventionId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([evidenceImpact])
}

model Product {
  id                  String       @id @default(cuid())
  interventionId      String?
  name                String
  brand               String
  labelText           String?
  servingSize         String?
  ingredientsJson     Json
  proprietaryBlend    Boolean      @default(false)
  certificationsJson  Json
  region              String       @default("AU")
  regulatoryNumber    String?
  qualityScore        Int
  labelClaimRiskScore Int
  url                 String?
  reviewStatus        ReviewStatus @default(UNREVIEWED_AI_DRAFT)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  intervention                Intervention?               @relation(fields: [interventionId], references: [id], onDelete: SetNull)
  australiaRegulatoryStatuses AustraliaRegulatoryStatus[]

  @@index([region])
  @@index([regulatoryNumber])
  @@index([qualityScore])
}

model SafetyAlert {
  id             String          @id @default(cuid())
  interventionId String?
  region         String          @default("AU")
  agency         SourceKind
  date           DateTime?
  alertType      SafetyAlertType
  severity       SafetySeverity
  summary        String
  url            String
  lastCheckedAt  DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  intervention Intervention? @relation(fields: [interventionId], references: [id], onDelete: SetNull)

  @@index([region])
  @@index([agency])
  @@index([severity])
}

model AustraliaRegulatoryStatus {
  id                  String                  @id @default(cuid())
  interventionId      String?
  productId           String?
  referenceId         String?
  region              String                  @default("AU")
  kind                AustraliaRegulatoryKind
  artgId              String?
  austNumber          String?
  sponsor             String?
  status              String
  efficacyAssessed    Boolean?
  preMarketAssessment Boolean?
  supplySummary       String
  evidenceRequirement String
  sourceUrl           String
  checkedAt           DateTime?
  notes               String
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  intervention Intervention? @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  product      Product?      @relation(fields: [productId], references: [id], onDelete: Cascade)
  reference    Reference?    @relation(fields: [referenceId], references: [id], onDelete: SetNull)

  @@index([region])
  @@index([kind])
  @@index([artgId])
  @@index([austNumber])
  @@index([interventionId])
  @@index([productId])
}

model SourceDocument {
  id               String       @id @default(cuid())
  referenceId      String?
  source           SourceKind
  url              String
  title            String
  rawText          String?
  extractedSummary String?
  checksum         String?
  retrievedAt      DateTime     @default(now())
  reviewStatus     ReviewStatus @default(UNREVIEWED_AI_DRAFT)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  reference Reference? @relation(fields: [referenceId], references: [id], onDelete: SetNull)

  @@unique([url])
  @@index([source])
  @@index([reviewStatus])
}

model SourceCandidate {
  id                  String                  @id @default(cuid())
  dedupeKey           String                  @unique
  source              SourceKind
  externalId          String
  query               String
  region              String                  @default("AU")
  title               String
  url                 String
  publishedYear       Int?
  sourceType          String?
  abstractAvailable   Boolean?
  triageScore         Int                     @default(0)
  triageReasons       String[]
  metadata            Json?
  decision            SourceCandidateDecision @default(PENDING_REVIEW)
  reviewStatus        ReviewStatus            @default(UNREVIEWED_AI_DRAFT)
  interventionId      String?
  claimId             String?
  ingestionJobId      String?
  acceptedReferenceId String?
  reviewedAt          DateTime?
  reviewNote          String?
  discoveredAt        DateTime                @default(now())
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  intervention      Intervention? @relation(fields: [interventionId], references: [id], onDelete: SetNull)
  claim             Claim?        @relation(fields: [claimId], references: [id], onDelete: SetNull)
  ingestionJob      IngestionJob? @relation(fields: [ingestionJobId], references: [id], onDelete: SetNull)
  acceptedReference Reference?    @relation(fields: [acceptedReferenceId], references: [id], onDelete: SetNull)

  @@index([source])
  @@index([externalId])
  @@index([region])
  @@index([decision])
  @@index([reviewStatus])
  @@index([interventionId])
  @@index([claimId])
  @@index([ingestionJobId])
  @@index([acceptedReferenceId])
  @@index([triageScore])
}

model IngestionJob {
  id             String          @id @default(cuid())
  source         SourceKind
  status         IngestionStatus @default(QUEUED)
  query          String
  region         String          @default("AU")
  interventionId String?
  claimId        String?
  startedAt      DateTime?
  completedAt    DateTime?
  recordsFound   Int             @default(0)
  recordsChanged Int             @default(0)
  error          String?
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  intervention     Intervention?     @relation(fields: [interventionId], references: [id], onDelete: SetNull)
  claim            Claim?            @relation(fields: [claimId], references: [id], onDelete: SetNull)
  sourceCandidates SourceCandidate[]

  @@index([source])
  @@index([status])
  @@index([region])
  @@index([interventionId])
  @@index([claimId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  operatorProfile     OperatorProfile?
  operatorAuditEvents OperatorAuditEvent[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OperatorProfile {
  id         String         @id @default(cuid())
  userId     String         @unique
  role       OperatorRole
  status     OperatorStatus @default(ACTIVE)
  note       String?
  disabledAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([role])
  @@index([status])
}

model OperatorAuditEvent {
  id            String       @id @default(cuid())
  actorUserId   String?
  actorEmail    String
  actorRole     OperatorRole
  action        String
  targetType    String
  targetId      String?
  requestId     String?
  beforeSummary Json?
  afterSummary  Json?
  metadata      Json?
  note          String?
  createdAt     DateTime     @default(now())

  actorUser User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([actorEmail])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}
