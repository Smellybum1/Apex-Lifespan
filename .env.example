# Local Docker Compose PostgreSQL:
# - Service: postgres
# - Database: apex_lifespan
# - User/password: postgres/postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/apex_lifespan?schema=public"
APEX_DATA_SOURCE="auto"

# Optional local-only Codex review sidecar. Generate a private token locally.
# APEX_CODEX_THREAD_ID=""
# APEX_CODEX_REVIEW_TOKEN=""
# APEX_CODEX_REVIEW_PORT="3217"

# Optional: send a contact email with NCBI requests when this becomes a scheduled job.
NCBI_TOOL="apex-lifespan"
NCBI_EMAIL=""
