# Local Docker Compose PostgreSQL:
# - Service: postgres
# - Database: apex_lifespan
# - User/password: postgres/postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/apex_lifespan?schema=public"

# Dashboard data mode:
# - Local default: "auto" reads PostgreSQL when reachable and falls back to seed data.
# - Recommended public MVP/demo: "seed" for read-only seed-backed public deploys.
# - Managed production database: "database" to fail closed when PostgreSQL is unavailable.
APEX_DATA_SOURCE="auto"

# Optional local-only Codex review sidecar. Generate private values locally;
# do not configure these in public deploy environments.
# APEX_CODEX_THREAD_ID=""
# APEX_CODEX_REVIEW_TOKEN=""
# APEX_CODEX_REVIEW_PORT="3217"
# APEX_CODEX_REVIEW_ORIGINS="http://127.0.0.1:3000,http://localhost:3000"
# APEX_CODEX_REVIEW_TIMEOUT_MS="120000"
# APEX_CODEX_MODEL=""

# Operator/admin auth. Leave unset for the public seed-backed demo.
# Configure only with managed PostgreSQL and an operator-only GitHub OAuth app.
# AUTH_SECRET=""
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""
# APEX_OPERATOR_WRITES_ENABLED="false"
# APEX_OPERATOR_ACTIVE_ACCOUNT_READY="false"
# APEX_OPERATOR_NONPROD_WRITE_QA_AT=""
# APEX_OPERATOR_FLOW_QA_REVIEWED_AT=""
# APEX_OPERATOR_BROWSER_WRITE_CONTROLS_APPROVED_AT=""

# Production migration rehearsal evidence. Use only after verifying the target is
# a non-production managed database and reviewing the rehearsal output.
# APEX_VERCEL_PROJECT_CONFIGURED_AT=""
# APEX_VERCEL_DATABASE_CONFIGURED_AT=""
# APEX_VERCEL_DATABASE_MODE_CONFIGURED_AT=""
# APEX_VERCEL_OPERATOR_AUTH_CONFIGURED_AT=""
# APEX_MIGRATION_REHEARSAL_TARGET="non-production"
# APEX_MIGRATION_REHEARSAL_PASSED_AT=""

# Scheduled ingestion controls and evidence. Leave scheduled writes disabled
# until managed database mode, alerts, NCBI metadata, and operator approval exist.
# APEX_SCHEDULED_INGESTION_WRITES_ENABLED="false"
# APEX_SCHEDULED_INGESTION_CRON_APPROVED="false"
# APEX_INGESTION_ALERTS_CONFIGURED="false"
# APEX_INGESTION_RETRY_POLICY_APPROVED_AT=""

# Fully-live operations evidence. Fill only after external tools/checks exist.
# APEX_UPTIME_MONITORING_URL=""
# APEX_ERROR_MONITORING_PROJECT=""
# APEX_DEPLOYMENT_ALERTS_CONFIGURED="false"
# APEX_DATABASE_BACKUPS_CONFIGURED="false"
# APEX_BACKUP_RESTORE_REHEARSED_AT=""
# APEX_ROLLBACK_DRILL_REHEARSED_AT=""
# APEX_ALERT_TESTED_AT=""

# Fully-live launch evidence. Fill only after the named launch checks pass.
# APEX_PUBLIC_SMOKE_PASSED_AT=""
# APEX_ADMIN_FLOW_SMOKE_PASSED_AT=""
# APEX_FULLY_LIVE_LAUNCH_APPROVED_AT=""
# APEX_POST_LAUNCH_REVIEW_SCHEDULED_AT=""

# Optional: send a contact email with NCBI requests when this becomes a scheduled job.
NCBI_TOOL="apex-lifespan"
NCBI_EMAIL=""
