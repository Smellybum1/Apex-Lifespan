# Local Docker Compose PostgreSQL:
# - Service: postgres
# - Database: apex_lifespan
# - User/password: postgres/postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/apex_lifespan?schema=public"

# Dashboard data mode:
# - Local default: "auto" reads PostgreSQL when reachable and falls back to seed data.
# - Recommended public MVP/demo: "seed" for read-only seed-backed public deploys.
# - Managed production database: "database" to fail closed when PostgreSQL is unavailable.
APEX_DATA_SOURCE="auto"

# Optional local-only Codex review sidecar. Generate private values locally;
# do not configure these in public deploy environments.
# APEX_CODEX_THREAD_ID=""
# APEX_CODEX_REVIEW_TOKEN=""
# APEX_CODEX_REVIEW_PORT="3217"
# APEX_CODEX_REVIEW_ORIGINS="http://127.0.0.1:3000,http://localhost:3000"
# APEX_CODEX_REVIEW_TIMEOUT_MS="120000"
# APEX_CODEX_MODEL=""

# Operator/admin auth. Leave unset for the public seed-backed demo.
# Configure only with managed PostgreSQL and an operator-only GitHub OAuth app.
# AUTH_SECRET=""
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""
# APEX_OPERATOR_WRITES_ENABLED="false"
# APEX_SCHEDULED_INGESTION_WRITES_ENABLED="false"

# Optional: send a contact email with NCBI requests when this becomes a scheduled job.
NCBI_TOOL="apex-lifespan"
NCBI_EMAIL=""
